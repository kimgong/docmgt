<Window x:Class="DocMgt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文档管理系统" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧文件列表 -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="文件列表" FontWeight="Bold" FontSize="16"/>
                <Button Content="刷新" Margin="0,10,0,0" Height="25" Click="Refresh_Click"/>
            </StackPanel>

            <ListBox Grid.Row="1" x:Name="FileList"
                     Margin="10,0,10,10"
                     SelectionChanged="FileList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 右侧内容预览 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="文件预览" FontWeight="Bold" FontSize="16"/>
                <TextBlock x:Name="FileNameText" Margin="0,5,0,0" Foreground="Gray"/>
            </StackPanel>

            <WebBrowser Grid.Row="1" x:Name="PreviewBrowser" Margin="10,0,10,10"/>
        </Grid>
    </Grid>
</Window>
