<UserControl x:Class="DocMgt.Views.DocumentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch" Width="200" Height="25"
                     VerticalAlignment="Center"/>
            <Button Content="搜索" Width="70" Height="25" Margin="10,0,0,0"
                    Click="Search_Click"/>
            <Button Content="上传" Width="70" Height="25" Margin="20,0,0,0"
                    Click="Upload_Click"/>
            <Button Content="刷新" Width="70" Height="25" Margin="10,0,0,0"
                    Click="Refresh_Click"/>
        </StackPanel>

        <!-- 文档列表 -->
        <DataGrid Grid.Row="1" x:Name="dgDocuments"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="50"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedTime}" Width="150"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="下载" Width="70" Height="25"
                    Click="Download_Click"/>
            <Button Content="删除" Width="70" Height="25" Margin="10,0,0,0"
                    Click="Delete_Click"/>
            <Button Content="预览" Width="70" Height="25" Margin="10,0,0,0"
                    Click="Preview_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
